# ===== Metis FinOps 프로토타입 환경설정 =====
# 이 파일을 .env 로 복사한 뒤 키를 채우세요. 키가 없으면 mock 프로바이더로 동작합니다.

# 실제 LLM API 키 (선택 — 비우면 mock 으로 동작)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=

# Azure OpenAI (설정 시 gpt-* / o3 모델은 Azure 로 우선 라우팅)
AZURE_OPENAI_ENDPOINT=        # 예: https://myresource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=      # 비우면 모델명=배포명 으로 호출

# 테스트 에이전트가 리뷰에 사용할 모델
TEST_AGENT_MODEL=gpt-4o

# 서비스 포트
CONTROL_PLANE_PORT=8500
GATEWAY_PORT=8400

# 게이트웨이 -> 컨트롤플레인 주소 (docker compose 에서는 http://control-plane:8500 으로 덮어씀)
LEDGER_URL=http://127.0.0.1:8500

# 시뮬레이터 동작
SIM_ENABLED=1
SIM_RPS=0.8
SIM_USE_REAL_API=0   # 1로 바꾸면 시뮬레이터도 실제 API 키로 호출(비용 발생 주의!)
