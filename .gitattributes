# 기본: 텍스트 파일은 Git이 자동 판별하고, 저장소에는 LF로 정규화
* text=auto eol=lf

# Windows 전용 스크립트는 CRLF 유지 (배치/PS1)
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# 셸 스크립트는 항상 LF (CRLF면 실행 안 됨)
*.sh    text eol=lf

# 바이너리: 줄바꿈 변환 금지 (손상 방지)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.xlsx  binary
*.pptx  binary
*.docx  binary
