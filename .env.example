# ── Database ──
DATABASE_URL="postgresql://metis:metis_secret@localhost:5432/metis_dev?schema=public"

# ── Redis ──
REDIS_URL="redis://localhost:6379"

# ── Auth ──
AUTH_SECRET="change-me-in-production-use-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:3000"

# ── API ──
API_PORT=4000
API_PREFIX="/v1"
CORS_ORIGIN="http://localhost:3000"

# ── Worker ──
WORKER_CONCURRENCY=5

# ── SMTP (Email Sending) ──
# For Gmail: use App Password (2FA required → https://myaccount.google.com/apppasswords)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM_NAME="Metis.AI"
# SMTP_FROM_EMAIL="your-email@gmail.com"

# ── Observability ──
OTEL_SERVICE_NAME="metis-api"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
LOG_LEVEL="debug"
# Protect GET /metrics/prometheus with a static bearer token (recommended in prod)
# METRICS_TOKEN="change-me"

# ── FinOps (F1~F4) ──
# Budget enforcement mode: off | downshift (default) | block
#   downshift: over daily limit → force Tier 1 (cheapest) routing
#   block:     ≥120% of limit  → LLM calls are refused with a clear error
# FINOPS_BUDGET_ENFORCE="downshift"
# Allow the Skill Packer to hard-truncate prompts over packerMaxTokensPerSkill
# (content loss — off by default; compression without truncation is always safe)
# FINOPS_PACKER_TRUNCATE="false"
# Auto-inject Anthropic prompt-caching breakpoints for stable knowledge prefixes
# FINOPS_PROVIDER_CACHE="true"

# ── Optional LLM Gateway (LiteLLM — docker compose --profile gateway) ──
# Route all provider traffic through the gateway WITHOUT code changes:
# OPENAI_BASE_URL="http://localhost:4400/v1"
# ANTHROPIC_BASE_URL="http://localhost:4400/anthropic"
# LITELLM_MASTER_KEY="sk-metis-litellm-master"
