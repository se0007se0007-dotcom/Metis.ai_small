{
  "name": "@metis/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "prisma generate --schema=../../prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=../../prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=../../prisma/schema.prisma",
    "push": "prisma db push --schema=../../prisma/schema.prisma --accept-data-loss",
    "seed": "tsx ../../prisma/seed.ts",
    "studio": "prisma studio --schema=../../prisma/schema.prisma",
    "build": "tsc --build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "6.19.3"
  },
  "devDependencies": {
    "prisma": "6.19.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
