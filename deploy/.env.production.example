# ─────────────────────────────────────────────────────────────
# METIS — 사내망(Production) 환경변수 템플릿
# 비밀값은 Git에 올리지 말고 K8s Secret / Azure Key Vault로 주입하세요.
# ─────────────────────────────────────────────────────────────

# [필수] PostgreSQL (신청한 Azure DB for PostgreSQL)
#   sslmode=require 권장
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/metis?schema=public&sslmode=require

# [필수] Redis (기존 구현 그대로 사용 가능 — Azure Cache for Redis 또는 클러스터 내 Redis)
#   TLS면 rediss:// 사용
REDIS_URL=redis://HOST:6379

# [필수] 인증/암호화 시크릿 (32자 이상 랜덤)  →  openssl rand -hex 32
AUTH_SECRET=CHANGE_ME_32B_RANDOM
METIS_SECRET_KEY=CHANGE_ME_32B_RANDOM

# [필수] LLM 키 (품질 평가/요약 등). 사내망 egress 정책 확인 필요(아래 가이드 참고)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# [선택] LLM 엔드포인트 오버라이드 — 소스 수정 없이 내부/프록시/자체 호스팅으로 전환
#   · 공개 LLM 프록시: 프록시 게이트웨이 URL을 넣으세요.
#   · 자체 qwen3.5 (OpenAI 호환): OPENAI_BASE_URL을 사내 엔드포인트로, OPENAI_MODEL을 모델명으로,
#     EVALUATOR_JUDGE_MODEL도 같은 모델명으로 지정하면 OpenAI 경로로 라우팅됩니다.
#   비우면 기본값(api.openai.com / api.anthropic.com) 사용.
# OPENAI_BASE_URL=http://qwen-gateway.intra:8000/v1
# ANTHROPIC_BASE_URL=https://anthropic-proxy.intra
# OPENAI_MODEL=qwen2.5-72b-instruct
# OPENAI_EMBED_MODEL=text-embedding-3-small
# EVALUATOR_JUDGE_MODEL=qwen2.5-72b-instruct

# [중요] 쿠키 secure 플래그 — HTTP 전용 사내망이면 반드시 false (안 그러면 로그인 실패)
#   미설정 시 NODE_ENV=production이면 자동 true. HTTPS 종단 없는 내부망은 false 고정.
COOKIE_SECURE=false

# [필수] API/CORS
API_PORT=4000
API_PREFIX=v1
NODE_ENV=production
# 사내 접속 도메인 (웹). 쉼표로 다중 허용
CORS_ORIGIN=https://metis.intra.example.com

# [필수] 웹 → API 프록시 (웹 컨테이너용)
NEXT_PUBLIC_API_URL=http://metis-api:4000/v1

# [필수] 파일 저장 위치 (영구볼륨 마운트 경로)
UPLOAD_DIR=/data/uploads
OUTPUT_DIR=/data/outputs

# [선택] 레이트리밋
RATE_LIMIT=100
RATE_LIMIT_WINDOW_MS=60000

# [선택] 평가 비용 가드
EVALUATOR_SAMPLE_RATE=1.0
EVALUATOR_BUDGET_PER_DAY=50

# [선택] SMTP (메일 발송)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_EMAIL=

# [선택] 관측성
OTEL_SERVICE_NAME=metis-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=info

# [선택] OCR(AWS Textract) 사용 시
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# OCR_TEXTRACT_REGION=
# OCR_TEXTRACT_TEMP_BUCKET=

# [선택] 워커
WORKER_CONCURRENCY=5
